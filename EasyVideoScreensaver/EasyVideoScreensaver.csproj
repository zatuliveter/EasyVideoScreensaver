<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>EasyVideoScreensaver</RootNamespace>
    <AssemblyName>EasyVideoScreensaver</AssemblyName>
    <ApplicationIcon>video.ico</ApplicationIcon>
    <StartupObject>EasyVideoScreensaver.App</StartupObject>
    <LangVersion>latest</LangVersion>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Debug'">
    <DefineConstants>DEBUG;TRACE</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="LibVLCSharp" Version="3.9.7.1" />
    <PackageReference Include="LibVLCSharp.WPF" Version="3.9.7.1" />
    <PackageReference Include="VideoLAN.LibVLC.Windows" Version="3.0.23.1" />
  </ItemGroup>
  <ItemGroup>
    <Resource Include="video.ico" />
  </ItemGroup>
  <PropertyGroup>
    <PostBuildEvent>copy "$(TargetDir)EasyVideoScreensaver.exe" "$(TargetDir)EasyVideoScreensaver.scr" /y</PostBuildEvent>
  </PropertyGroup>
</Project>
